{
  "name": "vitrin-web",
  "version": "0.1.0",
  "private": true,
  "description": "Vitrin — marketing site, auth, store-owner dashboard, and platform admin panel (Next.js 16).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "i18n:check": "node scripts/fe-qa/i18n-check.mjs",
    "check:hardcoded": "node scripts/fe-qa/check-hardcoded.mjs",
    "check:size": "node scripts/fe-qa/check-size.mjs",
    "lint": "npm run i18n:check && npm run check:hardcoded && npm run check:size",
    "prebuild": "npm run lint"
  },
  "dependencies": {
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
