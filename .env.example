# ACIP — environment template
# Copy to .env and adjust. NEVER commit the real .env (REQ-M1-010).
#
# Defaults below target LOCAL dev where the datastores run in Docker but you run
# the app on the host (the common case). When you run EVERYTHING inside Docker
# Compose, the api/gateway/worker services override these hosts with the internal
# names (elasticsearch/postgres/redis) automatically — you don't change anything.

# --- App ---
ACIP_ENV=development
ACIP_LOG_LEVEL=INFO
ACIP_SERVICE_NAME=acip

# --- Public API / Gateway ---
API_HOST=0.0.0.0
API_PORT=8000
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# --- Elasticsearch (data spine, REQ-M1-001) ---
# Dev compose runs ES with security OFF (no password), published on localhost:9200.
# Production enables auth + CA-verified TLS (https) and sets ES_PASSWORD (REQ-M1-003).
ES_HOST=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=
ES_VERIFY_CERTS=false

# --- PostgreSQL 18 (control plane, REQ-M1-004) ---
PG_HOST=localhost
PG_PORT=5432
PG_DB=acip
PG_USER=acip
PG_PASSWORD=acip

# --- Redis 8 (cache + queue, REQ-M1-005) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Self-hosted inference (REQ-M1-006); opt-in via `--profile inference` ---
EMBEDDINGS_URL=http://localhost:8080
RERANKER_URL=http://localhost:8081
LLM_URL=http://localhost:8000

# --- Operator/admin plane (separate from tenant keys, REQ-M11-004) ---
ADMIN_TOKEN=change-me-operator-token

# --- Human identity & auth (Phase 5: platform admins / store owners) ---
# AUTH_SECRET MUST be a long random string in production (e.g. `openssl rand -hex 32`).
# Empty = token issuance disabled (login fails closed).
AUTH_SECRET=
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
SIGNUP_ENABLED=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
TRIAL_PLAN_CODE=free

# --- Billing / buy-plan (Phase 7, provider-agnostic) ---
# 'manual' works out of the box (operator confirms payment). For a real gateway,
# set the provider + a webhook signing secret (HMAC-SHA256); empty = webhooks off.
BILLING_PROVIDER=manual
BILLING_WEBHOOK_SECRET=
SUBSCRIPTION_PERIOD_DAYS=30

# --- Notifications (email) + verification + product surfaces (Phase A) ---
# 'console' logs emails (dev); 'smtp' sends via the SMTP_* settings.
EMAIL_PROVIDER=console
EMAIL_FROM=Vitrin <no-reply@vitrin.ai>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
APP_BASE_URL=http://localhost:3000
CONTACT_INBOX=hello@vitrin.ai
EMAIL_VERIFICATION_REQUIRED=true

# --- Security hardening (Phase D) ---
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=false                 # set true only when served over HTTPS
CORS_ALLOW_ORIGINS=                # comma-separated; empty falls back to APP_BASE_URL
COOKIE_SECURE=false                # true in production (HTTPS)
COOKIE_SAMESITE=lax
CSRF_ENABLED=true
AUTH_IP_RATE_PER_MIN=10

# --- Phase 1: search / index / embedding tuning (M2/M4/M5/M6) ---
CATALOGUE_ALIAS=acip-products
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMS=1024
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANK_ENABLED=false          # eval-gated; enable only if golden-set NDCG justifies it
SEARCH_DEFAULT_SIZE=20
RRF_RANK_CONSTANT=60
RRF_RANK_WINDOW=100
KNN_K=100
KNN_NUM_CANDIDATES=200
SEMANTIC_CACHE_THRESHOLD=0.92
INDEX_SHARDS=1
INDEX_REPLICAS=1
