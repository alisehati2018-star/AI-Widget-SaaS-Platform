# ACIP — environment template (Phase 0)
# Copy to .env and fill in. NEVER commit the real .env (REQ-M1-010).
# In production, source these from a secret store, not a file.

# --- App ---
ACIP_ENV=development
ACIP_LOG_LEVEL=INFO
ACIP_SERVICE_NAME=acip

# --- Public API / Gateway (the only externally-exposed services, REQ-M1-009) ---
API_HOST=0.0.0.0
API_PORT=8000
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# --- Elasticsearch 9.2+ (data spine, REQ-M1-001) ---
ES_HOST=https://elasticsearch:9200
ES_USERNAME=elastic
ES_PASSWORD=change-me-in-secret-store
# Dev convenience only; production uses CA-verified TLS (REQ-M1-003).
ES_VERIFY_CERTS=false

# --- PostgreSQL 16 (control plane, REQ-M1-004) ---
PG_HOST=postgres
PG_PORT=5432
PG_DB=acip
PG_USER=acip
PG_PASSWORD=change-me-in-secret-store

# --- Redis 7 (cache + queue, REQ-M1-005) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Self-hosted inference (REQ-M1-006); compose-only in Phase 0 ---
EMBEDDINGS_URL=http://embeddings:80
RERANKER_URL=http://reranker:80
LLM_URL=http://llm:8000

# --- Observability (REQ-M12-004/011) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=acip
