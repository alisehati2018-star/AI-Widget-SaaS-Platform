msgid "ACIP — Smart Search & Assistant"
msgstr "ACIP — جست‌وجوی هوشمند و دستیار"

msgid "ACIP — Smart Search & Assistant requires WooCommerce to be installed and active."
msgstr "افزونهٔ ACIP — جست‌وجوی هوشمند و دستیار نیاز به نصب و فعال‌بودن ووکامرس دارد."

msgid "Settings"
msgstr "تنظیمات"

msgid "ACIP Search"
msgstr "جست‌وجوی ACIP"

msgid "Enabled"
msgstr "فعال"

msgid "Activate ACIP"
msgstr "فعال‌سازی ACIP"

msgid "ACIP API URL"
msgstr "آدرس API ACIP"

msgid "Test connection"
msgstr "آزمایش اتصال"

msgid "Connected — the API is reachable."
msgstr "اتصال برقرار شد — API در دسترس است."

msgid "Could not reach the ACIP API. Check the URL and try again."
msgstr "اتصال به API ACIP برقرار نشد. آدرس را بررسی و دوباره تلاش کنید."

msgid "Widget API Key"
msgstr "کلید API ویجت"

msgid "Storefront search + chat (least privilege)."
msgstr "جست‌وجو و گفت‌وگوی فروشگاه (کمترین سطح دسترسی)."

msgid "Sync API Key"
msgstr "کلید API همگام‌سازی"

msgid "Catalogue ingest. Keep server-side."
msgstr "ورود کاتالوگ. باید فقط سمت سرور نگه داشته شود."

msgid "Replace native search"
msgstr "جایگزینی جست‌وجوی پیش‌فرض"

msgid "Use ACIP results on the shop search page"
msgstr "استفاده از نتایج ACIP در صفحهٔ جست‌وجوی فروشگاه"

msgid "Initial catalogue import"
msgstr "ورود اولیهٔ کاتالوگ"

msgid "Push every published product to ACIP to build the index."
msgstr "همهٔ محصولات منتشرشده را برای ساخت ایندکس به ACIP ارسال می‌کند."

msgid "Bulk import now"
msgstr "ورود کامل اکنون"

msgid "Forbidden."
msgstr "دسترسی غیرمجاز."

msgid "Working…"
msgstr "در حال انجام…"

msgid "Imported %d products."
msgstr "%d محصول وارد شد."

msgid "Failed. Check your keys and try again."
msgstr "ناموفق بود. کلیدها را بررسی و دوباره تلاش کنید."
